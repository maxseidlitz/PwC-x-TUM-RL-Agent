# Kopiere diese Datei zu .env und fülle die Werte aus
# NIEMALS .env in Git committen!

# E-Mail (Absender = dein Gmail/etc. Account)
EMAIL_SENDER=deine-email@gmail.com
EMAIL_PASSWORD=dein-app-passwort       # Gmail App-Passwort, nicht das normale Passwort
EMAIL_RECIPIENT=deine-email@gmail.com  # Wohin der Tagesbericht geht

# Bewerber-Profil (für E-Mail-Personalisierung)
APPLICANT_NAME=Max Mustermann
APPLICANT_AGE=28
APPLICANT_OCCUPATION=Software-Entwickler
APPLICANT_INCOME=3.000 € netto
APPLICANT_MOVE_IN=01.08.2025

# Optional: Slack-Benachrichtigungen
SLACK_WEBHOOK_URL=

# Optional: SendGrid statt SMTP
# SENDGRID_API_KEY=SG.xxxxx

# Optional: PostgreSQL statt SQLite
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=wohnungssuche
# DB_USER=postgres
# DB_PASSWORD=secret
